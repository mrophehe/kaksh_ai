# =============================================================================
# Kaksh AI Environment Variables
# Copy this file to .env.local and fill in the values you need.
# All variables are optional — only configure the providers you want to use.
# You can also use server-providers.yml for configuration (see docs).
# =============================================================================

# --- LLM Providers -----------------------------------------------------------
# Format: {PROVIDER}_API_KEY, {PROVIDER}_BASE_URL (optional), {PROVIDER}_MODELS (optional, comma-separated)

OPENAI_API_KEY=sk-emergent-c6749E4090f68D2De9
OPENAI_BASE_URL=
OPENAI_MODELS=gpt-5.4-mini,gpt-5.4,gpt-5.4-nano,gpt-5-mini,gpt-5,gpt-5-nano,gpt-5.1,gpt-4.1,gpt-4.1-mini,gpt-4.1-nano,gpt-4o-mini

ANTHROPIC_API_KEY=sk-emergent-c6749E4090f68D2De9
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=claude-sonnet-4-6,claude-sonnet-4-5-20250929,claude-sonnet-4-20250514,claude-haiku-4-5-20251001,claude-opus-4-6,claude-opus-4-5-20251101,claude-opus-4-1-20250805,claude-opus-4-20250514

GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.5-pro,gemini-3-flash-preview,gemini-3-pro-preview,gemini-3.1-pro-preview

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODELS=openai/gpt-oss-20b,openai/gpt-oss-120b,llama-3.1-8b-instant,llama-3.3-70b-versatile,meta-llama/llama-4-scout-17b-16e-instruct

# Ollama Cloud (https://ollama.com/cloud) — requires API key from ollama.com settings
# For local Ollama OpenAI-compat, change to http://localhost:11434/v1 and use any non-empty API key value
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_MODELS=gpt-oss:20b,gpt-oss:120b,devstral-small-2:24b,devstral-2:123b,ministral-3:8b,ministral-3:14b,gemma3:4b,gemma3:12b,gemma3:27b

# --- TTS (Text-to-Speech) ----------------------------------------------------

TTS_OPENAI_API_KEY=
TTS_OPENAI_BASE_URL=

TTS_AZURE_API_KEY=
TTS_AZURE_BASE_URL=

TTS_ELEVENLABS_API_KEY=
TTS_ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1

# --- ASR (Automatic Speech Recognition) --------------------------------------

ASR_OPENAI_API_KEY=
ASR_OPENAI_BASE_URL=

# --- PDF Processing -----------------------------------------------------------

PDF_UNPDF_API_KEY=
PDF_UNPDF_BASE_URL=

# --- Image Generation ---------------------------------------------------------

IMAGE_NANO_BANANA_API_KEY=
IMAGE_NANO_BANANA_BASE_URL=https://generativelanguage.googleapis.com

# --- Video Generation ---------------------------------------------------------

VIDEO_VEO_API_KEY=
VIDEO_VEO_BASE_URL=https://generativelanguage.googleapis.com

VIDEO_SORA_API_KEY=
VIDEO_SORA_BASE_URL=

# --- Web Search ---------------------------------------------------------------

FIRECRAWL_API_KEY=

# --- Proxy (optional) --------------------------------------------------------

# HTTP_PROXY=
# HTTPS_PROXY=

# --- ElevenLabs (Voice Agent) -------------------------------------------------

ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# --- Misc ---------------------------------------------------------------------

# Optional server-side default model for API routes like /api/generate-classroom
# Example: anthropic:claude-sonnet-4-6 or google:gemini-3-flash-preview
DEFAULT_MODEL=

